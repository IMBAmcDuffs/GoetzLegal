{
	"compilerOptions": {
		"target": "ES2020",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"outDir": "./dist",
		"rootDir": "./resources/ts",
		"declaration": false,
		"sourceMap": true
	},
	"include": ["resources/ts/**/*.ts"],
	"exclude": ["node_modules", "dist"]
}
