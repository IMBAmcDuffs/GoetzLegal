# Wordpress - ignore core, configuration, examples, uploads and logs.
# https://github.com/github/gitignore/blob/main/WordPress.gitignore

# Core
#
# Note: if you want to stage/commit WP core files
# you can delete this whole section/until Configuration.
/wp-admin/
/wp-content/index.php
/wp-content/languages
/wp-content/plugins/index.php
/wp-content/themes/index.php
/wp-includes/
/index.php
/license.txt
/readme.html
/wp-*.php
/xmlrpc.php

/.env*
!.env.example

# Configuration
wp-config.php

# Example themes
/wp-content/themes/twenty*/

# Example plugin
/wp-content/plugins/hello.php

# Installed third-party plugins managed by the local setup
/wp-content/plugins/akismet/
/wp-content/plugins/wordpress-seo/
/wp-content/plugins/wpforms-lite/

# Uploads
/wp-content/uploads/

# Log files
*.log

# Local environment
/.env

# Local verification artifacts, including visual candidates and diffs
/artifacts/
/.superpowers/

# Local development exports
/__dev/

# htaccess
/.htaccess

# All plugins
#
# Note: If you wish to whitelist plugins,
# uncomment the next line
#/wp-content/plugins

# All themes
#
# Note: If you wish to whitelist themes,
# uncomment the next line
#/wp-content/themes

# Theme build artifacts and dependencies
wp-content/themes/goetz-legal/node_modules/
wp-content/themes/goetz-legal/dist/
wp-content/themes/goetz-legal/vendor/

# Root, first-party plugin, and browser test dependencies/build output
/vendor/
/wp-content/plugins/goetz-site/node_modules/
/wp-content/plugins/goetz-site/build/
/tests/e2e/node_modules/
/tests/e2e/test-results/
/tests/e2e/playwright-report/
/.phpunit.result.cache
